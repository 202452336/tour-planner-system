{
    "name": "backend",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "test": "cross-env NODE_ENV=test jest --detectOpenHandles",
        "test:blackbox": "cross-env NODE_ENV=test jest __tests__/blackbox*.test.js --detectOpenHandles",
        "test:whitebox": "cross-env NODE_ENV=test jest __tests__/whitebox*.test.js --detectOpenHandles",
        "test:coverage": "cross-env NODE_ENV=test jest --coverage --detectOpenHandles"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "axios": "^1.8.4",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "mysql2": "^3.20.0"
    },
    "devDependencies": {
        "cross-env": "^10.1.0",
        "jest": "^30.3.0",
        "nodemon": "^3.1.14",
        "supertest": "^7.2.2"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/__tests__/**/*.test.js"
        ],
        "collectCoverageFrom": [
            "controllers/**/*.js",
            "routes/**/*.js",
            "middleware/**/*.js"
        ],
        "coverageThreshold": {
            "global": {
                "branches": 50,
                "functions": 50,
                "lines": 50,
                "statements": 50
            }
        },
        "setupFilesAfterEnv": [
            "<rootDir>/__tests__/setup.js"
        ]
    }
}